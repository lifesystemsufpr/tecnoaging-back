# Example environment variables
# Copy this file to .env and configure for your environment

# Environment
NODE_ENV=development

# Backend Port
# IMPORTANT: The backend is configured to bind to 127.0.0.1 (localhost only)
# External access is handled by nginx reverse proxy
# This provides better security - the backend is not directly exposed to the internet
NEST_PORT=3333

## Security config
JWT_SECRET="your-super-secure-jwt-secret-change-this-in-production"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"